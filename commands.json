{
  "!greeting": "hello",
  "!echo": {
    "response": "You said: {args}",
    "match": "exact",
    "rate_limit": 3
  },
  "!say": {
    "response": "I hear: {0}",
    "match": "regex",
    "pattern": "^say\\s+(.+)$"
  },
  "!ping": "pong",
  "!help": "Available commands: !greeting, !echo, !say, !ping, !commands, !startready, !ready, !readylist, !createevent, !signup, !signups, !events, !addcmd"
}